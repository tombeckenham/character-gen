{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "promise", "node", "react"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "max-lines-per-function": ["warn", { "max": 150 }],
    "max-lines": ["warn", { "max": 600 }],
    "import/max-dependencies": ["warn", { "max": 20 }]
  },
  "overrides": [
    {
      "files": ["packages/engine/src/gallery-data.ts", "packages/engine/src/types.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["node:*"],
                "message": "This module is bundled into the browser SPA and must stay node-free."
              }
            ]
          }
        ]
      }
    }
  ],
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist", ".output", "node_modules"]
}
